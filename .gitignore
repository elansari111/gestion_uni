# ── Fichiers uploadés (photos & documents des étudiants) ──────
uploads/photos/*
uploads/documents/*

# Garder les dossiers vides avec leur protection
!uploads/photos/.htaccess
!uploads/photos/index.php
!uploads/documents/.htaccess
!uploads/documents/index.php
!uploads/.htaccess
!uploads/index.php

# ── Environnement & config sensible ───────────────────────────
